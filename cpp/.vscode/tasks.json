{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ File", // 建议与 launch.json 中的 preLaunchTask 保持一致
            "type": "shell",
            "command": "clang++", // Mac 原生编译器是 clang++
            "args": [
                "-std=c++20",
                "-g", // 必须加上 -g，否则无法进行断点调试
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}" // 去掉 .exe，Mac 不需要后缀
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}